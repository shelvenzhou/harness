# Copy to .env and fill in. .env is git-ignored.

# Required
OPENAI_API_KEY=sk-...

# Optional — defaults shown
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MAX_TOKENS=1024
# OPENAI_TEMPERATURE=0.7

# Harness behaviour
# HARNESS_PROVIDER=openai
# HARNESS_SYSTEM_PROMPT=You are a helpful agent. Respond concisely.
# HARNESS_STORE_ROOT=.harness/sessions

# Hot-path micro-compaction (on by default; values shown are defaults)
# HARNESS_MICRO_COMPACT=on            # on | off
# HARNESS_MICRO_COMPACT_KEEP_RECENT=20
# HARNESS_MICRO_COMPACT_TRIGGER_EVERY=10
# HARNESS_MICRO_COMPACT_MIN_BYTES=256

# Diagnostics (on by default)
# HARNESS_DIAG=off               # disable all sinks
# HARNESS_DIAG_DIR=.harness/diag # JSONL + prompt-dump root (default); 'off' disables the file sink
# HARNESS_DIAG_STDERR=summary    # summary (default) | verbose | off
