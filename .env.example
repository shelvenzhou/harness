# Copy to .env and fill in. .env is git-ignored.

# Required
OPENAI_API_KEY=sk-...

# Optional
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_MODE=responses       # responses | chat_completions
# OPENAI_MAX_TOKENS=32768
#
# Chat Completions compatibility. Most OpenAI models accept
# max_completion_tokens; some OpenAI-compatible/local endpoints still
# expect max_tokens.
# OPENAI_CHAT_MAX_TOKENS_PARAM=max_completion_tokens  # max_completion_tokens | max_tokens
#
# Only set temperature for models that support it. GPT-5 / o-series
# reasoning models reject this parameter, so the provider suppresses it
# for those model families even if this value is set.
# OPENAI_TEMPERATURE=0.7
#
# Responses API reasoning controls. Unset uses the model default effort
# and streams an automatic summary for reasoning-capable models.
# OPENAI_REASONING_EFFORT=medium      # none | minimal | low | medium | high | xhigh
# OPENAI_REASONING_SUMMARY=auto       # auto | concise | detailed | off

# Harness behaviour
# HARNESS_PROVIDER=openai
# HARNESS_MAIN_MODEL=main         # alias from HARNESS_MODEL_ALIASES, or a raw model id
# HARNESS_SYSTEM_PROMPT=You are a helpful agent. Respond concisely.
# HARNESS_STORE_ROOT=.harness/sessions

# Multiple model aliases. Aliases are registered as subagent providers,
# so a model can call spawn({provider:"fast", ...}) or
# spawn({provider:"local", ...}) while the main agent uses HARNESS_MAIN_MODEL.
# The selected alias/model metadata is injected into the system prompt as
# a `[runtime model]` block so the agent can report its configured model.
#
# Format:
#   HARNESS_MODEL_<ALIAS>=openai|model|apiMode|baseURL|apiKeyEnv
#
# Empty trailing fields inherit the global OPENAI_* settings. apiMode is
# responses or chat_completions. apiKeyEnv lets an alias use a different
# env var, e.g. OPENROUTER_API_KEY.
# HARNESS_MODEL_ALIASES=main,fast,local
# HARNESS_MODEL_MAIN=openai|gpt-5.4|responses||
# HARNESS_MODEL_FAST=openai|gpt-4o-mini|chat_completions||
# OPENAI_LOCAL_API_KEY=ollama
# HARNESS_MODEL_LOCAL=openai|qwen2.5-coder|chat_completions|http://localhost:11434/v1|OPENAI_LOCAL_API_KEY
#
# Each alias also accepts per-alias overrides for tuning knobs not in the
# `HARNESS_MODEL_<ALIAS>` line. The suffix is the alias uppercased with
# non-alphanumerics turned into `_` (so `local` → `LOCAL`, `gpt-4` →
# `GPT_4`). When unset, the alias inherits the global `OPENAI_*` value.
#
#   OPENAI_MAX_TOKENS_<ALIAS>              per-alias max tokens
#   OPENAI_TEMPERATURE_<ALIAS>             per-alias temperature
#   OPENAI_REASONING_EFFORT_<ALIAS>        none|minimal|low|medium|high|xhigh
#   OPENAI_REASONING_SUMMARY_<ALIAS>       auto|concise|detailed|off
#   OPENAI_CHAT_MAX_TOKENS_PARAM_<ALIAS>   max_completion_tokens|max_tokens
#
# Example: the local Ollama endpoint accepts `max_tokens` rather than
# `max_completion_tokens`.
# OPENAI_CHAT_MAX_TOKENS_PARAM_LOCAL=max_tokens
# OPENAI_REASONING_EFFORT_FAST=low

# Persistent memory (off by default — InMemoryStore is process-scoped).
# Pick ONE of the two backends below.
#
# (1) JSONL on disk — local persistence, single-process, no semantic search.
# HARNESS_MEMORY_FILE=.harness/memory.jsonl
#
# (2) mem0 — cross-process, LLM fact extraction + vector search.
#     Cloud: get a key at https://app.mem0.ai
#     Self-hosted: also set MEM0_BASE_URL=http://localhost:8000
# MEM0_API_KEY=m0-...
# MEM0_BASE_URL=
# MEM0_USER_ID=shelven   # default 'harness' if unset

# Web search (off by default — `web_search` returns 'unsupported' until configured).
# Pick ONE provider; when both are set, HARNESS_SEARCH_PROVIDER picks, else Tavily wins.
#
# (1) Google Programmable Search — needs both an API key and a CSE id (cx).
#     https://developers.google.com/custom-search/v1/overview
# GOOGLE_SEARCH_API_KEY=
# GOOGLE_SEARCH_CX=
# GOOGLE_SEARCH_BASE_URL=        # override endpoint (testing / proxying)
#
# (2) Tavily — LLM-optimized search; clean snippets + optional one-line answer.
#     https://tavily.com
# TAVILY_API_KEY=tvly-...
# TAVILY_SEARCH_DEPTH=basic      # basic | advanced
# TAVILY_INCLUDE_ANSWER=         # 1 to request a synthesized one-line answer
# TAVILY_BASE_URL=               # override endpoint (testing / self-host)
#
# HARNESS_SEARCH_PROVIDER=       # google | tavily — force selection when both keys are set

# Cold-path compaction (off by default — uncomment to enable a subagent-backed
# summary pass when projection token estimate crosses the threshold).
# HARNESS_COMPACTION_THRESHOLD_TOKENS=80000
# HARNESS_COMPACTION_COOLDOWN_SAMPLES=5
# HARNESS_COMPACTOR=subagent     # default: StaticCompactor placeholder

# Hot-path micro-compaction (on by default; values shown are defaults)
# HARNESS_MICRO_COMPACT=on            # on | off
# HARNESS_MICRO_COMPACT_KEEP_RECENT=20
# HARNESS_MICRO_COMPACT_TRIGGER_EVERY=10
# HARNESS_MICRO_COMPACT_MIN_BYTES=256

# Diagnostics (on by default)
# HARNESS_DIAG=off               # disable all sinks
# HARNESS_DIAG_DIR=.harness/diag # JSONL + prompt-dump root (default); 'off' disables the file sink
# HARNESS_DIAG_STDERR=summary    # summary (default) | verbose | off

# Discord adapter
# HARNESS_ADAPTER=discord
# DISCORD_BOT_TOKEN=
# DISCORD_CHANNEL_ID=            # optional; if unset, first @bot per channel creates a session.
# HARNESS_STORE_ROOT=            # Per-channel mappings persist across restarts when HARNESS_STORE_ROOT is set.
